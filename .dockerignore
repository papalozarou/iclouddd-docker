# ------------------------------------------------------------------------------
# Baseline `.dockerignore` for new Dockerised projecs to keep the build context
# small and free of secrets and local state.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Project-specific ignores.
# ------------------------------------------------------------------------------
.github/
.git/
.gitignore
.shellcheckrc
AGENTS.md
CODE_REVIEW.md
CONFIGURATION.md
LICENSE
OPERATIONS.md
PROMPT.md
README.md
SCHEDULING.md
TELEGRAM.md
TODO.md
check-traversal-workers.sh
coverage.xml
scratchpad.sh
scripts/check_docs.py
test.sh

# ------------------------------------------------------------------------------
# Environment and secrets.
# ------------------------------------------------------------------------------
.env
.env.*.local
.env.local
secrets/

# ------------------------------------------------------------------------------
# Python artifacts.
# ------------------------------------------------------------------------------
.coverage
.coverage.*
.mypy_cache/
.pytest_cache/
.venv/
*.py[cod]
*.pyd
__pycache__/
venv/

# ------------------------------------------------------------------------------
# Node and frontend artifacts.
# ------------------------------------------------------------------------------
.next/
.nuxt/
.svelte-kit/
coverage/
node_modules/

# ------------------------------------------------------------------------------
# Runtime and compose files.
# ------------------------------------------------------------------------------
compose.yml
compose.build.yml
config/
data/
docker-compose.yml
logs/
output/
tests/

# ------------------------------------------------------------------------------
# IDE and operating system files.
# ------------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
